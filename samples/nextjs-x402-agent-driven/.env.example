# Anthropic API key — required. The translation agent calls Claude twice
# per paid turn (planning + final summary) plus once for the actual
# translation work.
ANTHROPIC_API_KEY=

# Optional: override the Claude model. Defaults to claude-sonnet-4-20250514.
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# The wallet address that receives payments. Required for premium calls.
X402_MERCHANT_ADDRESS=0x0000000000000000000000000000000000000000

# Optional: override the x402 facilitator URL.
# Default: https://x402.org/facilitator
# X402_FACILITATOR_URL=https://my-facilitator.example.com

# Optional: override the base URL emitted in the AgentCard.
# BASE_URL=http://localhost:3000

# Development mode: skip real verify/settle and always succeed with a fake
# receipt. Useful for running the sample without funding a Base Sepolia
# wallet. Never set this in production.
# X402_MOCK_FACILITATOR=1

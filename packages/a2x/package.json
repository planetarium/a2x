{
  "name": "@a2x/sdk",
  "version": "0.1.0",
  "type": "module",
  "description": "A2A (Agent-to-Agent) protocol SDK for TypeScript",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.cjs"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js",
      "require": "./dist/auth/index.cjs"
    },
    "./anthropic": {
      "types": "./dist/provider/anthropic/index.d.ts",
      "import": "./dist/provider/anthropic/index.js",
      "require": "./dist/provider/anthropic/index.cjs"
    },
    "./openai": {
      "types": "./dist/provider/openai/index.d.ts",
      "import": "./dist/provider/openai/index.js",
      "require": "./dist/provider/openai/index.cjs"
    },
    "./google": {
      "types": "./dist/provider/google/index.d.ts",
      "import": "./dist/provider/google/index.js",
      "require": "./dist/provider/google/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.52.0",
    "@google/genai": ">=1.0.0",
    "openai": ">=4.0.0",
    "zod": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "@google/genai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@google/genai": "^1.50.0",
    "@types/node": "^25.6.0",
    "openai": "^6.34.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/planetarium/a2x.git",
    "directory": "packages/a2x"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["a2a", "agent-to-agent", "ai", "agent", "sdk", "protocol"],
  "license": "MIT"
}
